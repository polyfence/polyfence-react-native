# Polyfence RN Example app environment.
#
# Copy this file to .env, paste your Polyfence API key into POLYFENCE_API_KEY,
# then rebuild the native app. react-native-config bakes the value into
# BuildConfig (Android) and Info.plist (iOS) at build time.
#
# Get a free key by signing up at https://polyfence.io.

POLYFENCE_API_URL=https://polyfence.io/api/zones
POLYFENCE_API_KEY=
