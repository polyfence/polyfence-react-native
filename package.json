{
  "name": "polyfence-react-native",
  "version": "1.0.7",
  "description": "Polyfence React Native bridge — privacy-first geofencing, same zones across mobile/IoT/server. Bridge over polyfence-core.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "lib/module/index",
  "source": "src/index",
  "files": [
    "lib",
    "android",
    "ios",
    "polyfence-react-native.podspec",
    "!android/build",
    "!android/.gradle",
    "!android/local.properties",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/gradle",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "build": "bob build",
    "test": "jest",
    "clean": "del-cli lib"
  },
  "keywords": [
    "react-native",
    "geofencing",
    "geofence",
    "polygon",
    "location",
    "privacy",
    "on-device",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polyfence/polyfence-react-native.git"
  },
  "author": "Polyfence <hello@polyfence.io> (https://polyfence.io)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/polyfence/polyfence-react-native/issues"
  },
  "homepage": "https://github.com/polyfence/polyfence-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^2.8.8",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
